DATABASE_URL=sqlite:./portfolio.db

# Hetzner Object Storage (S3-compatible)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
STORAGE_ENDPOINT=https://hel1.your-objectstorage.com
STORAGE_BUCKET=portfolio-images
STORAGE_PUBLIC_URL=https://portfolio-images.hel1.your-objectstorage.com

# WebAuthn — must match your domain exactly when deployed
# For local dev use localhost values below
RP_ID=yourdomain.com
RP_ORIGIN=https://yourdomain.com
